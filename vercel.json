{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "protalentconnect.co.in"
        }
      ],
      "destination": "https://www.protalentconnect.co.in/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "protalentconnect.com"
        }
      ],
      "destination": "https://www.protalentconnect.co.in/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.protalentconnect.com"
        }
      ],
      "destination": "https://www.protalentconnect.co.in/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pro-talent-connect-frontend.vercel.app"
        }
      ],
      "destination": "https://www.protalentconnect.co.in/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
